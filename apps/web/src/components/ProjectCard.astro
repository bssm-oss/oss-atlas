---
import type { AtlasProject } from '../types/atlas';
import { dictionaries, formatDateByLocale, projectPath, type Locale } from '../lib/i18n';

interface Props {
  project: AtlasProject;
  showCategory?: boolean;
  lang?: Locale;
}

const { project, showCategory = true, lang = 'en' } = Astro.props;
const t = dictionaries[lang];
const projectHref = projectPath(lang, project.name, import.meta.env.BASE_URL);
---

<article class="project-card">
  <div class="project-top">
    <a class="project-name" href={projectHref}>{project.name}</a>
    <span class="status-pill" data-status={project.status}>{project.status}</span>
  </div>

  <p class="project-pitch">{project.pitch}</p>

  {project.description && <p class="project-description">{project.description}</p>}

  <div class="project-meta">
    {showCategory && <span class="tag">{project.category}</span>}
    {project.language && <span class="tag">{project.language}</span>}
    {project.difficulty && <span class="tag">{project.difficulty}</span>}
    <span class="tag">{project.stars} {t.card.stars}</span>
    <span class="tag">{project.forks} {t.card.forks}</span>
    <span class="tag">{t.card.updatedPrefix} {formatDateByLocale(project.pushedAt ?? project.updatedAt, lang)}</span>
  </div>
</article>
