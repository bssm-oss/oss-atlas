---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { atlas, projectByName } from '../../../lib/atlas';
import { dictionaries, formatDateByLocale, homePath, projectPath, type Locale } from '../../../lib/i18n';
import type { AtlasProject } from '../../../types/atlas';

export function getStaticPaths() {
  return atlas.projects.map((project) => ({
    params: { name: project.name },
    props: { project }
  }));
}

const { project } = Astro.props;
const lang: Locale = 'ko';
const t = dictionaries[lang];
const rawBaseUrl = import.meta.env.BASE_URL;
const related = project.relatedRepos
  .map((repoName: string) => projectByName.get(repoName))
  .filter((repo): repo is AtlasProject => Boolean(repo));
---

<BaseLayout
  title={`${project.name} | ${atlas.organization.name} ${t.project.titleSuffix}`}
  description={project.pitch}
  organizationName={atlas.organization.name}
  generatedAt={atlas.generatedAt}
  lang={lang}
  currentProjectName={project.name}
>
  <p style="margin-top: var(--space-6);">
    <a href={homePath(lang, rawBaseUrl)}>{t.project.backToOverview}</a>
  </p>

  <section class="detail-header" aria-labelledby="project-detail-title">
    <p class="detail-subtitle">{t.project.detailSubtitle}</p>
    <h1 id="project-detail-title" class="detail-title">{project.name}</h1>
    <p class="detail-text">{project.pitch}</p>
    {project.description && <p class="detail-text">{project.description}</p>}

    <div class="project-meta">
      <span class="status-pill" data-status={project.status}>{project.status}</span>
      <span class="tag">{project.category}</span>
      {project.language && <span class="tag">{project.language}</span>}
      {project.difficulty && <span class="tag">{project.difficulty}</span>}
    </div>
  </section>

  <section class="detail-shell" aria-label={t.project.metadataAriaLabel}>
    <article class="detail-panel">
      <h2>{t.project.metadataTitle}</h2>
      <div class="meta-list" style="margin-top: var(--space-4);">
        <div class="meta-row">
          <span class="meta-label">{t.project.metaRepository}</span>
          <span class="meta-value">{project.fullName}</span>
        </div>
        <div class="meta-row">
          <span class="meta-label">{t.project.metaStars}</span>
          <span class="meta-value">{project.stars}</span>
        </div>
        <div class="meta-row">
          <span class="meta-label">{t.project.metaForks}</span>
          <span class="meta-value">{project.forks}</span>
        </div>
        <div class="meta-row">
          <span class="meta-label">{t.project.metaLicense}</span>
          <span class="meta-value">{project.license ?? t.project.notDeclared}</span>
        </div>
        <div class="meta-row">
          <span class="meta-label">{t.project.metaLastPush}</span>
          <span class="meta-value">{formatDateByLocale(project.pushedAt ?? project.updatedAt, lang)}</span>
        </div>
      </div>

      <div style="margin-top: var(--space-5); display: flex; flex-wrap: wrap; gap: var(--space-3);">
        <a href={project.url}>{t.project.repositoryLink}</a>
        {project.homepageUrl && <a href={project.homepageUrl}>{t.project.homepageLink}</a>}
      </div>
    </article>

    <article class="detail-panel">
      <h2>{t.project.contributionAtlasTitle}</h2>
      <p class="section-note" style="margin-top: var(--space-2);">{t.project.contributionAtlasNote}</p>

      <h3 style="margin-top: var(--space-4);">{t.project.maintainersTitle}</h3>
      {project.maintainers.length > 0 ? (
        <div class="contribution-cloud" style="margin-top: var(--space-3);">
          {project.maintainers.map((maintainer: string) => (
            <span class="tag">{maintainer}</span>
          ))}
        </div>
      ) : (
        <p class="empty-note" style="margin-top: var(--space-3);">{t.project.maintainersEmpty}</p>
      )}

      <h3 style="margin-top: var(--space-5);">{t.project.contributionTagsTitle}</h3>
      {project.contribution.length > 0 ? (
        <div class="contribution-cloud" style="margin-top: var(--space-3);">
          {project.contribution.map((tag: string) => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      ) : (
        <p class="empty-note" style="margin-top: var(--space-3);">{t.project.contributionTagsEmpty}</p>
      )}

      <h3 style="margin-top: var(--space-5);">{t.project.contributionSignalsTitle}</h3>
      {project.contributionSignals.length > 0 ? (
        <div class="contribution-cloud" style="margin-top: var(--space-3);">
          {project.contributionSignals.map((signal: string) => (
            <span class="tag">{signal}</span>
          ))}
        </div>
      ) : (
        <p class="empty-note" style="margin-top: var(--space-3);">{t.project.contributionSignalsEmpty}</p>
      )}
    </article>
  </section>

  <section class="section" aria-labelledby="taxonomy-title">
    <div class="section-heading">
      <h2 class="section-title" id="taxonomy-title">{t.project.taxonomyTitle}</h2>
      <p class="section-note">{t.project.taxonomyNote}</p>
    </div>

    <div class="duo-grid">
      <article class="tag-card">
        <h3>{t.project.topicsTitle}</h3>
        {project.topics.length > 0 ? (
          <div class="contribution-cloud" style="margin-top: var(--space-3);">
            {project.topics.map((topic: string) => (
              <span class="tag">{topic}</span>
            ))}
          </div>
        ) : (
          <p class="empty-note" style="margin-top: var(--space-3);">{t.project.topicsEmpty}</p>
        )}
      </article>

      <article class="tag-card">
        <h3>{t.project.techStackTitle}</h3>
        {project.techStack.length > 0 ? (
          <div class="contribution-cloud" style="margin-top: var(--space-3);">
            {project.techStack.map((item: string) => (
              <span class="tag">{item}</span>
            ))}
          </div>
        ) : (
          <p class="empty-note" style="margin-top: var(--space-3);">{t.project.techStackEmpty}</p>
        )}
      </article>
    </div>
  </section>

  <section class="section" aria-labelledby="related-title">
    <div class="section-heading">
      <h2 class="section-title" id="related-title">{t.project.relatedTitle}</h2>
      <p class="section-note">{t.project.relatedNote}</p>
    </div>

    {related.length > 0 ? (
      <div class="project-grid">
        {related.map((repo) => (
          <article class="project-card">
            <div class="project-top">
              <a class="project-name" href={projectPath(lang, repo.name, rawBaseUrl)}>{repo.name}</a>
              <span class="status-pill" data-status={repo.status}>{repo.status}</span>
            </div>
            <p class="project-pitch">{repo.pitch}</p>
          </article>
        ))}
      </div>
    ) : (
      <p class="empty-note">{t.project.relatedEmpty}</p>
    )}
  </section>
</BaseLayout>
