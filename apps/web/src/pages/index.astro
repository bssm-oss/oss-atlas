---
import BaseLayout from '../layouts/BaseLayout.astro';
import OrgAtlasExplorer from '../components/OrgAtlasExplorer.astro';
import ProjectCard from '../components/ProjectCard.astro';
import StatCard from '../components/StatCard.astro';
import {
  activeProjects,
  atlas,
  contributionTags,
  featuredProjects,
  projectsByCategory,
  recentProjects
} from '../lib/atlas';
import { dictionaries, projectPath, type Locale } from '../lib/i18n';

const lang: Locale = 'en';
const t = dictionaries[lang];
const projectHref = (name: string) => projectPath(lang, name, import.meta.env.BASE_URL);
---

<BaseLayout
  title={`${atlas.organization.name} | ${t.home.titleSuffix}`}
  description={atlas.organization.description}
  organizationName={atlas.organization.name}
  generatedAt={atlas.generatedAt}
  lang={lang}
>
  <OrgAtlasExplorer lang={lang} />

  <section class="hero" aria-labelledby="organization-heading">
    <p class="hero-kicker">{t.home.heroKicker}</p>
    <h1 id="organization-heading">{atlas.organization.name}</h1>
    <p>{atlas.organization.description ?? t.home.fallbackDescription}</p>
    {atlas.organization.url && (
      <p style="margin-top: var(--space-4);">
        <a href={atlas.organization.url}>{t.home.visitOrganizationProfile}</a>
      </p>
    )}
    <p class="tag" style="margin-top: var(--space-4); width: fit-content;">Generated sample atlas section</p>
  </section>

  <section class="section" aria-labelledby="stats-title">
    <div class="section-heading">
      <h2 class="section-title" id="stats-title">{t.home.statsTitle}</h2>
      <p class="section-note">{t.home.statsNote}</p>
    </div>
    <div class="stat-grid">
      <StatCard label={t.home.statTotalRepositories} value={atlas.stats.totalRepos} lang={lang} />
      <StatCard label={t.home.statFeaturedRepositories} value={atlas.stats.featuredRepos} lang={lang} />
      <StatCard label={t.home.statActiveRepositories} value={atlas.stats.activeRepos} lang={lang} />
      <StatCard label={t.home.statContributionReady} value={atlas.stats.contributionReadyRepos} lang={lang} />
      <StatCard label={t.home.statArchivedRepositories} value={atlas.stats.archivedRepos} lang={lang} />
    </div>

    {atlas.warnings.length > 0 && (
      <ul class="warning-list" style="margin-top: var(--space-5);">
        {atlas.warnings.map((warning) => (
          <li>{warning}</li>
        ))}
      </ul>
    )}
  </section>

  <section class="section" aria-labelledby="featured-title">
    <div class="section-heading">
      <h2 class="section-title" id="featured-title">{t.home.featuredTitle}</h2>
      <p class="section-note">{t.home.featuredNote}</p>
    </div>
    {featuredProjects.length > 0 ? (
      <div class="project-grid">
        {featuredProjects.map((project) => (
          <ProjectCard project={project} lang={lang} />
        ))}
      </div>
    ) : (
      <p class="empty-note">{t.home.featuredEmpty}</p>
    )}
  </section>

  <section class="section" aria-labelledby="activity-title">
    <div class="section-heading">
      <h2 class="section-title" id="activity-title">{t.home.activityTitle}</h2>
      <p class="section-note">{t.home.activityNote}</p>
    </div>

    <div class="duo-grid">
      <article class="category-card" aria-labelledby="active-projects-title">
        <h3 id="active-projects-title">{t.home.activeNowTitle}</h3>
        <ul>
          {activeProjects.slice(0, 8).map((project) => (
            <li>
              <a href={projectHref(project.name)}>{project.name}</a>
              <span>{project.stars} {t.card.stars}</span>
            </li>
          ))}
        </ul>
        {activeProjects.length === 0 && <p class="empty-note" style="margin-top: var(--space-3);">{t.home.activeEmpty}</p>}
      </article>

      <article class="category-card" aria-labelledby="recent-projects-title">
        <h3 id="recent-projects-title">{t.home.recentlyUpdatedTitle}</h3>
        <ul>
          {recentProjects.map((project) => (
            <li>
              <a href={projectHref(project.name)}>{project.name}</a>
              <span>{project.language ?? t.home.noLanguage}</span>
            </li>
          ))}
        </ul>
        {recentProjects.length === 0 && <p class="empty-note" style="margin-top: var(--space-3);">{t.home.recentEmpty}</p>}
      </article>
    </div>
  </section>

  <section class="section" aria-labelledby="categories-title">
    <div class="section-heading">
      <h2 class="section-title" id="categories-title">{t.home.categoriesTitle}</h2>
      <p class="section-note">{t.home.categoriesNote}</p>
    </div>

    <div class="project-grid">
      {projectsByCategory.map((category) => (
        <article class="category-card">
          <h3>{category.name}</h3>
          <p class="section-note">{category.count} {t.home.repositoriesCount}</p>
          <ul>
            {category.projects.slice(0, 4).map((project) => (
              <li>
                <a href={projectHref(project.name)}>{project.name}</a>
                <span>{project.status}</span>
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </section>

  <section class="section" aria-labelledby="contribution-title">
    <div class="section-heading">
      <h2 class="section-title" id="contribution-title">{t.home.contributionTagsTitle}</h2>
      <p class="section-note">{t.home.contributionTagsNote}</p>
    </div>

    {contributionTags.length > 0 ? (
      <div class="tag-card">
        <div class="contribution-cloud">
          {contributionTags.map((tag) => (
            <span class="tag">{tag.name} ({tag.count})</span>
          ))}
        </div>
      </div>
    ) : (
      <p class="empty-note">{t.home.contributionTagsEmpty}</p>
    )}
  </section>
</BaseLayout>
