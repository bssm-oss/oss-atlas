---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { atlas, formatDate, projectByName } from '../../lib/atlas';
import type { AtlasProject } from '../../types/atlas';

export function getStaticPaths() {
  return atlas.projects.map((project) => ({
    params: { name: project.name },
    props: { project }
  }));
}

const { project } = Astro.props;
const related = project.relatedRepos
  .map((repoName: string) => projectByName.get(repoName))
  .filter((repo): repo is AtlasProject => Boolean(repo));
---

<BaseLayout
  title={`${project.name} | ${atlas.organization.name} Atlas`}
  description={project.pitch}
  organizationName={atlas.organization.name}
  generatedAt={atlas.generatedAt}
>
  <p style="margin-top: var(--space-6);">
    <a href="/">Back to atlas overview</a>
  </p>

  <section class="detail-header" aria-labelledby="project-detail-title">
    <p class="detail-subtitle">Project Detail</p>
    <h1 id="project-detail-title" class="detail-title">{project.name}</h1>
    <p class="detail-text">{project.pitch}</p>
    {project.description && <p class="detail-text">{project.description}</p>}

    <div class="project-meta">
      <span class="status-pill" data-status={project.status}>{project.status}</span>
      <span class="tag">{project.category}</span>
      {project.language && <span class="tag">{project.language}</span>}
      {project.difficulty && <span class="tag">{project.difficulty}</span>}
    </div>
  </section>

  <section class="detail-shell" aria-label="project metadata and contribution details">
    <article class="detail-panel">
      <h2>Project Metadata</h2>
      <div class="meta-list" style="margin-top: var(--space-4);">
        <div class="meta-row">
          <span class="meta-label">Repository</span>
          <span class="meta-value">{project.fullName}</span>
        </div>
        <div class="meta-row">
          <span class="meta-label">Stars</span>
          <span class="meta-value">{project.stars}</span>
        </div>
        <div class="meta-row">
          <span class="meta-label">Forks</span>
          <span class="meta-value">{project.forks}</span>
        </div>
        <div class="meta-row">
          <span class="meta-label">License</span>
          <span class="meta-value">{project.license ?? 'Not declared'}</span>
        </div>
        <div class="meta-row">
          <span class="meta-label">Last push</span>
          <span class="meta-value">{formatDate(project.pushedAt ?? project.updatedAt)}</span>
        </div>
      </div>

      <div style="margin-top: var(--space-5); display: flex; flex-wrap: wrap; gap: var(--space-3);">
        <a href={project.url}>Repository</a>
        {project.homepageUrl && <a href={project.homepageUrl}>Homepage</a>}
      </div>
    </article>

    <article class="detail-panel">
      <h2>Contribution Atlas</h2>
      <p class="section-note" style="margin-top: var(--space-2);">Maintainers and contributor entry points</p>

      <h3 style="margin-top: var(--space-4);">Maintainers</h3>
      {project.maintainers.length > 0 ? (
        <div class="contribution-cloud" style="margin-top: var(--space-3);">
          {project.maintainers.map((maintainer: string) => (
            <span class="tag">{maintainer}</span>
          ))}
        </div>
      ) : (
        <p class="empty-note" style="margin-top: var(--space-3);">No maintainers listed.</p>
      )}

      <h3 style="margin-top: var(--space-5);">Contribution Tags</h3>
      {project.contribution.length > 0 ? (
        <div class="contribution-cloud" style="margin-top: var(--space-3);">
          {project.contribution.map((tag: string) => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      ) : (
        <p class="empty-note" style="margin-top: var(--space-3);">No contribution tags listed.</p>
      )}

      <h3 style="margin-top: var(--space-5);">Contribution Signals</h3>
      {project.contributionSignals.length > 0 ? (
        <div class="contribution-cloud" style="margin-top: var(--space-3);">
          {project.contributionSignals.map((signal: string) => (
            <span class="tag">{signal}</span>
          ))}
        </div>
      ) : (
        <p class="empty-note" style="margin-top: var(--space-3);">No contribution signals listed.</p>
      )}
    </article>
  </section>

  <section class="section" aria-labelledby="taxonomy-title">
    <div class="section-heading">
      <h2 class="section-title" id="taxonomy-title">Taxonomy</h2>
      <p class="section-note">Topics and stack references</p>
    </div>

    <div class="duo-grid">
      <article class="tag-card">
        <h3>Topics</h3>
        {project.topics.length > 0 ? (
          <div class="contribution-cloud" style="margin-top: var(--space-3);">
            {project.topics.map((topic: string) => (
              <span class="tag">{topic}</span>
            ))}
          </div>
        ) : (
          <p class="empty-note" style="margin-top: var(--space-3);">No topics detected.</p>
        )}
      </article>

      <article class="tag-card">
        <h3>Tech Stack</h3>
        {project.techStack.length > 0 ? (
          <div class="contribution-cloud" style="margin-top: var(--space-3);">
            {project.techStack.map((item: string) => (
              <span class="tag">{item}</span>
            ))}
          </div>
        ) : (
          <p class="empty-note" style="margin-top: var(--space-3);">No stack metadata detected.</p>
        )}
      </article>
    </div>
  </section>

  <section class="section" aria-labelledby="related-title">
    <div class="section-heading">
      <h2 class="section-title" id="related-title">Related Repositories</h2>
      <p class="section-note">Known links in the organization graph</p>
    </div>

    {related.length > 0 ? (
      <div class="project-grid">
        {related.map((repo) => (
          <article class="project-card">
            <div class="project-top">
              <a class="project-name" href={`/projects/${repo.name}/`}>{repo.name}</a>
              <span class="status-pill" data-status={repo.status}>{repo.status}</span>
            </div>
            <p class="project-pitch">{repo.pitch}</p>
          </article>
        ))}
      </div>
    ) : (
      <p class="empty-note">No related repositories were declared.</p>
    )}
  </section>
</BaseLayout>
