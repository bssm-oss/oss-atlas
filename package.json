{
  "name": "oss-atlas-workspace",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter @oss-atlas/web dev",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest",
    "verify": "pnpm test -- --run && pnpm build && node scripts/verify-static-site.mjs",
    "cli": "pnpm --filter oss-atlas exec oss-atlas"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  }
}
