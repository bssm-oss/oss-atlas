{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "oss-atlas catalog",
  "type": "object",
  "required": ["organization", "repos"],
  "properties": {
    "organization": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "url": { "type": "string" }
      },
      "additionalProperties": false
    },
    "repos": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "featured": { "type": "boolean" },
          "category": { "type": "string" },
          "status": { "enum": ["active", "maintenance", "archived"] },
          "pitch": { "type": "string" },
          "maintainers": { "type": "array", "items": { "type": "string" } },
          "contribution": { "type": "array", "items": { "type": "string" } },
          "difficulty": { "enum": ["easy", "medium", "hard"] },
          "techStack": { "type": "array", "items": { "type": "string" } },
          "relatedRepos": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
